module.exports = {
  daemon: true,
  run: [
    {
      method: "shell.run",
      params: {
        message: "uv run python server.py",
        on: [
          {
            event: "/Uvicorn running on/i",
            done: true
          }
        ]
      }
    },
    {
      when: "{{input.event && input.event.length > 0}}",
      method: "local.set",
      params: {
        url: "{{input.event[0]}}"
      }
    }
  ]
}